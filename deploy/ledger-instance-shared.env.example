# Telegram 机器人宿主机共享配置。
# 只需初始化一次，保存到 /etc/telegram-ledger/shared.env 并设置权限 600。

# 必填：所有机器人数据库共用的 PostgreSQL 登录密码。
POSTGRES_PASSWORD=replace_with_postgresql_password

# 以下默认值通常不需要修改。
POSTGRES_USER=ledger
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
PG_BIN_DIR=/www/server/pgsql/bin
BOT_IMAGE=ghcr.io/dayou0168/telegram-ledger-bot-go:2.4.12
BOT_DEFAULTS_FILE=/etc/telegram-ledger/config/bot-defaults.env

# 宿主机共享 watcher。
WATCHER_URL=http://127.0.0.1:8090
WATCHER_DATABASE_NAME=ledgerchainwatcher
WATCHER_ENV_FILE=/etc/ledger-chain-watcher/env
WATCHER_SERVICE=ledger-chain-watcher

# 宝塔路径。
COMPOSE_ROOT=/www/server/panel/data/compose
NGINX_VHOST_ROOT=/www/server/panel/vhost/nginx
NGINX_CERT_ROOT=/www/server/panel/vhost/cert
WWW_ROOT=/www/wwwroot
NGINX_BIN=/www/server/nginx/sbin/nginx
NGINX_RELOAD=/etc/init.d/nginx
