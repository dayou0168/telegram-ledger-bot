# Telegram 记账机器人 Go v2.3.6 环境变量样例

# 必填：BotFather 给你的机器人 Token。
TELEGRAM_BOT_TOKEN=123456:replace-me

# 必填：机器人用户名，不要带 @。
TELEGRAM_BOT_USERNAME=your_bot_username

# 必填：唯一宿主 Telegram 数字 ID。
# 私聊机器人发送“我的ID”获取。
BOT_HOST_USER_ID=123456789

# 必填：PostgreSQL 连接地址。
DATABASE_URL=postgres://ledger:change_this_strong_password@postgres:5432/ledger_bot?sslmode=disable

# 可选：服务器默认操作人，多个用英文逗号分隔。
DEFAULT_OPERATOR_USER_IDS=

# 时间全部使用北京时间。
BOT_TIMEZONE=Asia/Shanghai

# 网页账单/后台域名，必须带 https://，不要带 /day_xxb.php。
PUBLIC_BILL_BASE_URL=https://bot.example.com

# 后台登录密码。公网部署必须填写随机强密码。
ADMIN_WEB_TOKEN=change_this_admin_password

# Telegram API 地址。没有自建 Bot API Server 就保持默认。
TELEGRAM_API_BASE=https://api.telegram.org
BOT_POLL_TIMEOUT=50
BOT_REQUEST_TIMEOUT=30

# 4核8G推荐并发池。
BOT_WORKER_THREADS=16
BOT_CONTROL_THREADS=6
BOT_CHAIN_THREADS=12
BOT_RATE_THREADS=2
BOT_BROADCAST_THREADS=4
BOT_QUERY_THREADS=4
BOT_NOTIFICATION_THREADS=6
BOT_QUEUE_SIZE=4096

# 共享链上监听。机器人不再配置官网 API Key，也不再直接每秒扫链。
CHAIN_WATCHER_URL=http://ledger-chain-watcher:8090
CHAIN_WATCHER_BOT_ID=ledger-main
CHAIN_WATCHER_SECRET=change_this_chain_watcher_secret
CHAIN_WATCHER_POLL_SECONDS=1
CHAIN_WATCHER_BATCH_SIZE=50
# 正常模式只消费 watcher 事件；持续异常时由共享 PostgreSQL lease 选出一个无 Key leader fallback。
BOT_WATCHER_HEALTH_INTERVAL_SECONDS=1
BOT_WATCHER_FAIL_THRESHOLD=3
BOT_WATCHER_CLAIM_TIMEOUT_MS=2000
BOT_FALLBACK_POLL_SECONDS=1
BOT_FALLBACK_SHARED_DATABASE_URL=postgres://chainwatcher:change_this_chain_pg_password@chain-postgres:5432/ledger_chain_watcher?sslmode=disable
BOT_FALLBACK_INSTANCE_ID=
BOT_FALLBACK_LEASE_SECONDS=15
BOT_FALLBACK_HEAD_TIME_BUDGET_MS=850
BOT_FALLBACK_SAFETY_MAX_PAGES=256
BOT_FALLBACK_REQUEST_INTERVAL_MS=200
BOT_FALLBACK_RECOVERY_SUCCESS_ROUNDS=3
BOT_FALLBACK_RECOVERY_LAG_SECONDS=5
BOT_FALLBACK_MAX_REQUESTS_PER_TICK=6
BOT_FALLBACK_WINDOW_SECONDS=30

# chain-watcher 服务端配置。只在 ledger-chain-watcher 容器中使用。
CHAIN_WATCHER_DATABASE_URL=postgres://chainwatcher:change_this_chain_pg_password@chain-postgres:5432/ledger_chain_watcher?sslmode=disable
CHAIN_WATCHER_ADDR=:8090
CHAIN_WATCHER_ADMIN_TOKEN=change_this_watcher_admin_token
# Generate once with: openssl rand -base64 32
CHAIN_WATCHER_KEY_ENCRYPTION_KEY=replace_with_base64_32_byte_key
CHAIN_WATCHER_BOTS=ledger-main:change_this_chain_watcher_secret
CHAIN_WATCHER_TRONSCAN_API_BASE=https://apilist.tronscanapi.com/api
CHAIN_WATCHER_TRONSCAN_API_KEYS=replace_key_1,replace_key_2,replace_key_3
# Legacy single-key compatibility. Leave empty when API_KEYS is set.
CHAIN_WATCHER_TRONSCAN_API_KEY=
CHAIN_WATCHER_TRON_API_KEY=
CHAIN_WATCHER_SOURCE_POLL_SECONDS=1
CHAIN_WATCHER_MAIN_SCAN_TIMEOUT_MS=3000
# 实际二进制变量名；不要误写为 CHAIN_WATCHER_MAIN_SCAN_MAX_INFLIGHT。
CHAIN_WATCHER_MAIN_MAX_INFLIGHT_ROUNDS=3
# Deprecated compatibility only; fixed base-page scanning is ignored.
# CHAIN_WATCHER_GLOBAL_SCAN_PAGES=
CHAIN_WATCHER_HEAD_TIME_BUDGET_MS=850
CHAIN_WATCHER_HEAD_SAFETY_MAX_PAGES=256
CHAIN_WATCHER_HEAD_MAX_CONCURRENCY=32
# P1 uses a separate reserved persistence lane; this caps only P2..PN DB workers.
CHAIN_WATCHER_HEAD_PERSIST_CONCURRENCY=8
CHAIN_WATCHER_RECOVERY_SAFETY_MAX_PAGES=4096
CHAIN_WATCHER_SURPLUS_BURST_SECONDS=60
CHAIN_WATCHER_CATCHUP_ENABLED=true
CHAIN_WATCHER_CATCHUP_STATE_INTERVAL_SECONDS=30
CHAIN_WATCHER_CATCHUP_PAGE_LIMIT=3
CHAIN_WATCHER_CATCHUP_MAX_REQUESTS_PER_TICK=6
# Independent worker ceiling; actual catch-up concurrency follows surplus capacity.
CHAIN_WATCHER_CATCHUP_MAX_INFLIGHT=8
CHAIN_WATCHER_CATCHUP_WINDOW_SECONDS=30
CHAIN_WATCHER_CATCHUP_OVERLAP_SECONDS=2
# 0 uses dynamic spare healthy-key capacity; a positive value is an extra hard cap.
CHAIN_WATCHER_CATCHUP_MAX_RPS=0
CHAIN_WATCHER_CATCHUP_TARGET_LAG_SECONDS=30
CHAIN_WATCHER_CATCHUP_MAX_LAG_SECONDS=120
CHAIN_WATCHER_TRONSCAN_KEY_INTERVAL_MS=200
CHAIN_WATCHER_TRONSCAN_DAILY_LIMIT_PER_KEY=100000
# Legacy interval name; the new per-key setting above takes precedence.
CHAIN_WATCHER_TRON_REQUEST_INTERVAL_MS=250
CHAIN_WATCHER_KEY_AUTH_PROBE_SECONDS=5
CHAIN_WATCHER_KEY_INVALID_PROBE_SECONDS=1800
CHAIN_WATCHER_KEY_BLOCKED_PROBE_SECONDS=3600
CHAIN_WATCHER_LOOKBACK_SECONDS=600

# TRON/TRC20 查询和兼容配置。
TRONSCAN_API_BASE=https://apilist.tronscanapi.com/api
# 多 bot 通过共享 PostgreSQL lease 只选一个无 Key leader fallback；仅明确批准持久在线备用源时填写 Key。
TRONGRID_API_KEY=
TRON_USDT_CONTRACT=TR7NHqjeKQxGTCi8q8ZY4pL8otSzgjLj6t
# Deprecated compatibility only; ignored by ledger-chain-watcher.
# TRONSCAN_GLOBAL_SCAN_PAGES=
TRON_ADDRESS_BACKFILL_SECONDS=60
TRON_INITIAL_LOOKBACK_MINUTES=15

# Z0 / 实时汇率。默认 OKX OTC、USDT 卖 CNY、支付宝档位。
P2P_RATE_API_BASE=https://p2p.army/api/fapi
P2P_RATE_FRONT_API=NextVOF2Ozuh36mW0TCv
P2P_RATE_MARKET=okx
P2P_RATE_FIAT_UNIT=CNY
P2P_RATE_ASSET=USDT
P2P_RATE_TRADE_METHODS=aliPay
P2P_RATE_REFRESH_SECONDS=60
P2P_RATE_CACHE_TTL_SECONDS=180

# Global operator capability inputs only. PostgreSQL epoch/NOTIFY handles revocation correctness.
BOT_GLOBAL_PERMISSION_CACHE_TTL_SECONDS=60
BOT_GLOBAL_PERMISSION_CACHE_SIZE=4096

# 后台管理和短账单网页。
ADMIN_WEB_ENABLED=1
ADMIN_WEB_HOST=0.0.0.0
ADMIN_WEB_PORT=8080
