TELEGRAM_BOT_TOKEN=123456:replace-me
TELEGRAM_BOT_USERNAME=your_bot_username
# Use the service root only. Examples:
# TELEGRAM_API_BASE=https://api.telegram.org
# TELEGRAM_API_BASE=http://telegram-bot-api:8081
TELEGRAM_API_BASE=https://api.telegram.org
BOT_DB_PATH=data/ledger_bot.db
BOT_TIMEZONE=Asia/Shanghai
# The single host can manage default operators and use every bot feature.
# Send "我的ID" to the bot in private chat to get your Telegram ID.
BOT_HOST_USER_ID=
# Maintainers manage default operators here. The bot itself cannot add/delete them.
# Default operators can invite the bot, record in any group, and use broadcasts,
# but the single host must still be present in every group.
DEFAULT_OPERATOR_USER_IDS=
BOT_WORKER_THREADS=8
BOT_CHAIN_THREADS=8
BOT_RATE_THREADS=1
BOT_BROADCAST_THREADS=4
BOT_QUERY_THREADS=2
BOT_HOST_CHECK_TTL_SECONDS=300
# Optional, used at the bottom of "显示账单" replies.
# PUBLIC_BILL_BASE_URL=https://your-domain.example
# For a reference-style PHP bill page, use:
# PUBLIC_BILL_BASE_URL=https://your-domain.example/day_xxb.php
# PUBLIC_BILL_BOT_NAME=YOUR_BOT_CODE
#
# Advanced: override the whole button URL. Available placeholders:
# {chat_id}, {day_key}, {begin_time}, {end_time}, {all}, {bot_name}, {up_page}, {down_page}
# PUBLIC_BILL_URL_TEMPLATE=https://your-domain.example/day_xxb.php?firstname=&chat_id={chat_id}&up_page=1&down_page=1&created_at=&begintime={begin_time}&endtime={end_time}&all={all}&phpname={bot_name}&type=bjr

# TRON/TRC20 address watching. Mainnet TronGrid benefits from an API key.
TRONGRID_API_BASE=https://api.trongrid.io
# TRONGRID_API_KEY=your-trongrid-api-key
TRON_USDT_CONTRACT=TR7NHqjeKQxGTCi8q8ZY4pL8otSzgjLj6t
TRON_POLL_INTERVAL_SECONDS=5
TRON_INITIAL_LOOKBACK_MINUTES=15

# Z0/Z1 OTC rate source. Defaults to OKX USDT selling CNY with Alipay.
P2P_RATE_API_BASE=https://p2p.army/api/fapi
P2P_RATE_FRONT_API=NextVOF2Ozuh36mW0TCv
P2P_RATE_MARKET=okx
P2P_RATE_FIAT_UNIT=CNY
P2P_RATE_ASSET=USDT
P2P_RATE_TRADE_METHODS=aliPay
P2P_RATE_REFRESH_SECONDS=60
P2P_RATE_CACHE_TTL_SECONDS=180
